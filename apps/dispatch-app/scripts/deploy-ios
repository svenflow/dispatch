#!/bin/bash
# deploy-ios — Build and deploy dispatch-app to a connected iPhone
# Auto-detects device, cleans caches, and does a fresh build.
#
# Usage:
#   deploy-ios              # Full clean build + deploy
#   deploy-ios --quick      # Skip pod reinstall (faster, use when only JS changed)
#   deploy-ios --metro      # After deploy, ensure Metro is running for hot reload
#   deploy-ios --quick --metro  # Quick build + ensure Metro after
#
# Metro is daemon-managed and NOT killed during build. The build uses
# --no-bundler with a pre-exported JS bundle, so Metro can stay running.
# For faster JS iteration, use Metro hot reload instead of this script.

set -euo pipefail

APP_DIR="$HOME/dispatch/apps/dispatch-app"
METRO_CMD="$APP_DIR/scripts/metro"
cd "$APP_DIR"

QUICK=false
START_METRO=false

for arg in "$@"; do
  case "$arg" in
    --quick) QUICK=true ;;
    --metro) START_METRO=true ;;
  esac
done

# Note: Metro is daemon-managed — we do NOT kill it. Build uses --no-bundler
# with a pre-exported bundle, so Metro can stay running independently.
if curl -sf http://localhost:8081/status &>/dev/null; then
  echo "ℹ️  Metro is running (daemon-managed). Build uses pre-exported bundle independently."
  echo "   Tip: For JS-only changes, just save the file — Metro hot reload is ~2s."
fi

# 1. Auto-detect connected physical iPhone
echo "🔍 Detecting connected iPhone..."
DEVICE_LINE=$(xcrun xctrace list devices 2>&1 | grep -E "iPhone.*\([0-9]+\.[0-9]+(\.[0-9]+)?\) \(" | grep -v Simulator | head -1)

if [[ -z "$DEVICE_LINE" ]]; then
  echo "❌ No physical iPhone connected"
  exit 1
fi

# Extract UDID (last parenthesized value)
UDID=$(echo "$DEVICE_LINE" | grep -oE '\([A-F0-9-]+\)$' | tr -d '()')
DEVICE_NAME=$(echo "$DEVICE_LINE" | sed 's/ ([^)]*) ([^)]*)$//')

echo "📱 Found: $DEVICE_NAME ($UDID)"

# 2. Kill any existing expo build
pkill -f "expo run:ios" 2>/dev/null || true

# 3. Clean build artifacts
echo "🧹 Cleaning build artifacts..."
rm -rf ios/build

if [[ "$QUICK" == false ]]; then
  echo "🧹 Cleaning pods..."
  rm -rf ios/Pods
  npx pod-install 2>&1 | tail -3
fi

# 4. Export fresh JS bundle
echo "📦 Exporting JS bundle..."
npx expo export --platform ios --clear 2>&1 | tail -3

# 5. Build and deploy
echo "🔨 Building and deploying to $DEVICE_NAME..."
npx expo run:ios --device "$UDID" --configuration Release --no-bundler 2>&1 | tail -5

echo "✅ Deployed to $DEVICE_NAME"

# 6. Ensure Metro is running (daemon usually handles this, but --metro forces a check)
if [[ "$START_METRO" == true ]]; then
  echo ""
  if curl -sf http://localhost:8081/status &>/dev/null; then
    echo "✅ Metro already running (daemon-managed)"
  else
    echo "🔄 Starting Metro..."
    "$METRO_CMD" start
  fi
fi

echo ""
echo "💡 For JS changes, just save files — Metro hot reload is instant (~2s)."
echo "   Only use deploy-ios for native changes (pods, entitlements, plugins)."
