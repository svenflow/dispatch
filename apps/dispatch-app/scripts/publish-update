#!/usr/bin/env bash
#
# publish-update — Export a JS bundle and publish it as a self-hosted OTA update.
#
# Usage:
#   ./scripts/publish-update              # uses runtimeVersion from app.config.ts
#   ./scripts/publish-update --message "Fix quota widgets"
#
# The script:
#   1. Runs `npx expo export` to produce a dist/ folder (includes metadata.json with fileMetadata)
#   2. Copies the bundle + assets into updates/<runtimeVersion>/<timestamp>/
#   3. Merges custom fields into the existing metadata.json (preserves expo's fileMetadata)
#   4. The dispatch-api manifest endpoint automatically picks up the latest update
#
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
APP_DIR="$(cd "$SCRIPT_DIR/.." && pwd)"
cd "$APP_DIR"

# Parse args
MESSAGE=""
while [[ $# -gt 0 ]]; do
  case "$1" in
    --message|-m) MESSAGE="$2"; shift 2 ;;
    *) echo "Unknown arg: $1"; exit 1 ;;
  esac
done

# Extract runtimeVersion from app.config.ts output
RUNTIME_VERSION=$(npx expo config --json 2>/dev/null | grep -o '"runtimeVersion":"[^"]*"' | cut -d'"' -f4)
if [ -z "$RUNTIME_VERSION" ]; then
  echo "ERROR: Could not determine runtimeVersion from app.config.ts"
  exit 1
fi

TIMESTAMP=$(date +%s)
UPDATE_DIR="$APP_DIR/updates/$RUNTIME_VERSION/$TIMESTAMP"

echo "=== Publishing OTA Update ==="
echo "  Runtime version: $RUNTIME_VERSION"
echo "  Timestamp:       $TIMESTAMP"
echo "  Output:          $UPDATE_DIR"
[ -n "$MESSAGE" ] && echo "  Message:         $MESSAGE"
echo ""

# Export the JS bundle
echo "→ Running npx expo export..."
npx expo export --platform ios --output-dir "$APP_DIR/dist-ota" 2>&1

# Move to updates directory (preserves expo's metadata.json with fileMetadata)
echo "→ Moving bundle to updates directory..."
mkdir -p "$UPDATE_DIR"
cp -R "$APP_DIR/dist-ota/"* "$UPDATE_DIR/"

# Merge custom fields into expo's metadata.json (preserves fileMetadata)
if [ -f "$UPDATE_DIR/metadata.json" ]; then
  uv run python3 -c "
import json, sys
with open('$UPDATE_DIR/metadata.json') as f:
    meta = json.load(f)
meta['runtimeVersion'] = '$RUNTIME_VERSION'
meta['timestamp'] = $TIMESTAMP
meta['message'] = $(printf '%s' "$MESSAGE" | uv run python3 -c 'import json,sys; print(json.dumps(sys.stdin.read()))')
meta['createdAt'] = '$(date -u +%Y-%m-%dT%H:%M:%SZ)'
with open('$UPDATE_DIR/metadata.json', 'w') as f:
    json.dump(meta, f, indent=2)
"
else
  echo "WARNING: No metadata.json from expo export — creating minimal one"
  cat > "$UPDATE_DIR/metadata.json" <<METAEOF
{
  "runtimeVersion": "$RUNTIME_VERSION",
  "timestamp": $TIMESTAMP,
  "message": $(printf '%s' "$MESSAGE" | uv run python3 -c 'import json,sys; print(json.dumps(sys.stdin.read()))'),
  "createdAt": "$(date -u +%Y-%m-%dT%H:%M:%SZ)"
}
METAEOF
fi

# Also save expoConfig for the manifest endpoint
npx expo config --json 2>/dev/null > "$UPDATE_DIR/expoConfig.json" || true

# Clean up temp export
rm -rf "$APP_DIR/dist-ota"

echo ""
echo "✓ Update published to: $UPDATE_DIR"
echo ""
echo "Contents:"
find "$UPDATE_DIR" -type f | head -30

# Also rebuild the web export so the dispatch-api root endpoint stays in sync
echo ""
echo "→ Rebuilding web export..."
npx expo export --platform web 2>&1
if [ -f "$APP_DIR/dist/index.html" ]; then
  echo "✓ Web export updated"
else
  echo "⚠ Web export ran but index.html missing"
fi

echo ""
echo "The dispatch-api manifest endpoint will serve this automatically."
echo "Restart the app to pick up the update (or wait for next cold start)."
