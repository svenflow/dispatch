    """Run golden-set regression test for fact extraction. Phase 2 stub."""
    print("Error: 'fact test-extraction' is not yet implemented.", file=sys.stderr)
    print("Would run golden test cases to validate extraction prompt quality.", file=sys.stderr)
    sys.exit(1)


def cmd_gc(args):
    """Garbage-collect old deactivated facts (>180 days)."""
    conn = get_conn()
    try:
        result = conn.execute("""
            DELETE FROM facts
            WHERE active = 0
              AND updated_at < datetime('now', '-180 days')
        """)
        conn.commit()
        count = result.rowcount
        print(f"Deleted {count} old deactivated facts.")
    finally:
        conn.close()


def main():
    parser = argparse.ArgumentParser(description="Structured facts CLI")
    sub = parser.add_subparsers(dest="command", required=True)

    # save
    p = sub.add_parser("save", help="Save a new fact")
    p.add_argument("--contact", required=True, help="Contact chat_id")
    p.add_argument("--type", required=True, help="Fact type (travel, event, preference)")
    p.add_argument("--summary", required=True, help="Human-readable summary")
    p.add_argument("--details", help="JSON details blob")
    p.add_argument("--confidence", choices=["high", "medium", "low"], default="high")
    p.add_argument("--starts", help="Start date (ISO 8601 or natural like 'March 20')")
    p.add_argument("--ends", help="End date (ISO 8601 or natural like 'March 25')")
    p.add_argument("--source", default="manual", help="Source (sms, signal, email, calendar, manual)")
    p.add_argument("--source-ref", help="Source reference (bus:12345, gmail:msg_abc)")
    p.add_argument("--silent", action="store_true", help="Suppress bus events")
    p.add_argument("--json", action="store_true", help="Output as JSON")

    # update
    p = sub.add_parser("update", help="Update an existing fact")
    p.add_argument("id", type=int, help="Fact ID")
    p.add_argument("--summary", help="New summary")
    p.add_argument("--details", help="JSON details to merge")
    p.add_argument("--starts", help="New start date")
    p.add_argument("--ends", help="New end date")
    p.add_argument("--confidence", choices=["high", "medium", "low"])
    p.add_argument("--silent", action="store_true", help="Suppress bus events")
    p.add_argument("--json", action="store_true", help="Output as JSON")

    # list
    p = sub.add_parser("list", help="List facts")
    p.add_argument("--contact", help="Filter by contact")
    p.add_argument("--type", help="Filter by fact type")
    p.add_argument("--active", action="store_true", help="Only active facts")
    p.add_argument("--verbose", "-v", action="store_true", help="Show details JSON")
    p.add_argument("--limit", type=int, help="Limit number of results")
    p.add_argument("--json", action="store_true", help="Output as JSON")

    # search
    p = sub.add_parser("search", help="Search facts by summary")
    p.add_argument("query", help="Search query")
    p.add_argument("--all", action="store_true", help="Include inactive facts")
    p.add_argument("--json", action="store_true", help="Output as JSON")

    # upcoming
    p = sub.add_parser("upcoming", help="Show upcoming temporal facts")
    p.add_argument("--days", type=int, default=7, help="Number of days ahead (default 7)")
    p.add_argument("--json", action="store_true", help="Output as JSON")

    # deactivate
    p = sub.add_parser("deactivate", help="Deactivate a fact")
    p.add_argument("id", type=int, nargs="?", help="Fact ID")
    p.add_argument("--all", action="store_true", help="Deactivate ALL active facts")
    p.add_argument("--silent", action="store_true", help="Suppress bus events")

    # context
    p = sub.add_parser("context", help="Get formatted fact context for a contact")
    p.add_argument("--contact", required=True, help="Contact chat_id")
    p.add_argument("--json", action="store_true", help="Output as JSON")

    # inject
    p = sub.add_parser("inject", help="Inject facts into contact's CLAUDE.md")
    p.add_argument("--contact", required=True, help="Contact chat_id")

    # expire
    p = sub.add_parser("expire", help="Expire temporal facts past their end date")
    p.add_argument("--contact", help="Filter by contact")
    p.add_argument("--silent", action="store_true", help="Suppress bus events")

    # stale
    p = sub.add_parser("stale", help="Show stale non-temporal facts")
    p.add_argument("--contact", help="Filter by contact")
    p.add_argument("--json", action="store_true", help="Output as JSON")

    # audit
    sub.add_parser("audit", help="Show potential duplicate facts")

    # rebuild (Phase 2 stub)
    p = sub.add_parser("rebuild", help="Rebuild facts from bus history (Phase 2)")
    p.add_argument("--since", required=True, help="Rebuild from this date")
    p.add_argument("--silent", action="store_true", help="Suppress bus events")

    # import (Phase 2 stub)
    p = sub.add_parser("import", help="Import facts from extraction log (Phase 2)")
    p.add_argument("--from-log", required=True, help="Extraction log timestamp to import")
    p.add_argument("--silent", action="store_true", help="Suppress bus events")
    p.add_argument("--emit-events", action="store_true", help="Emit bus events (default: silent)")

    # test-extraction (Phase 2 stub)
    p = sub.add_parser("test-extraction", help="Run golden-set regression test (Phase 2)")
    p.add_argument("--golden-dir", help="Directory containing golden test cases")

    # gc
    sub.add_parser("gc", help="Garbage-collect old deactivated facts")

    args = parser.parse_args()

    commands = {
        "save": cmd_save,
        "update": cmd_update,
        "list": cmd_list,
        "search": cmd_search,
        "upcoming": cmd_upcoming,
        "deactivate": cmd_deactivate,
        "context": cmd_context,
        "inject": cmd_inject,
        "expire": cmd_expire,
        "stale": cmd_stale,
        "audit": cmd_audit,
        "rebuild": cmd_rebuild,
        "import": cmd_import,
        "test-extraction": cmd_test_extraction,
        "gc": cmd_gc,
    }

    commands[args.command](args)


if __name__ == "__main__":
    main()
