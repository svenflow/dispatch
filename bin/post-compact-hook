#!/usr/bin/env bash
# PostCompact hook script — called by Claude Code CLI via settings.json
# after compaction completes. Reads hook input from stdin (JSON).
#
# Produces compaction.completed bus event and logs to compactions.log.
# SMS notification is handled by the manager's bus consumer (conditional —
# only sends if user messaged during compaction).
#
# Usage (by Claude Code CLI, not manual):
#   echo '{"session_id":"...","cwd":"...","compact_summary":"..."}' | post-compact-hook

set -euo pipefail

HOME_DIR="$HOME"

# Read hook input from stdin
INPUT="$(cat)"

# Extract fields from JSON input
CWD=$(echo "$INPUT" | jq -r '.cwd // empty' 2>/dev/null || echo "")
COMPACT_SUMMARY=$(echo "$INPUT" | jq -r '.compact_summary // empty' 2>/dev/null || echo "")
SESSION_ID=$(echo "$INPUT" | jq -r '.session_id // empty' 2>/dev/null || echo "")

# Derive session_name from cwd: ~/transcripts/imessage/_15555550100 -> imessage/_15555550100
SESSION_NAME=""
if [[ "$CWD" == *"/transcripts/"* ]]; then
  SESSION_NAME="${CWD#*transcripts/}"
fi

# Derive chat_id and source from session_name
SOURCE=""
CHAT_ID=""
if [[ -n "$SESSION_NAME" ]]; then
  SOURCE="${SESSION_NAME%%/*}"
  RAW_CHAT_ID="${SESSION_NAME#*/}"
  # Convert _15555550100 back to +15555550100
  CHAT_ID="${RAW_CHAT_ID/#_/+}"
fi

TIMESTAMP=$(date "+%Y-%m-%d %H:%M:%S")

# 1. Log to compactions.log (always)
echo "$TIMESTAMP | HOOK | Compaction completed for $SESSION_NAME" >> "$HOME_DIR/dispatch/logs/compactions.log"

# 2. Archive compact summary (always)
if [[ -n "$CWD" && -n "$COMPACT_SUMMARY" ]]; then
  ARCHIVE_DIR="$CWD/.compactions"
  mkdir -p "$ARCHIVE_DIR"
  ARCHIVE_FILE="$ARCHIVE_DIR/$(date '+%Y%m%d-%H%M%S').md"
  echo "# Compaction Summary" > "$ARCHIVE_FILE"
  echo "" >> "$ARCHIVE_FILE"
  echo "$COMPACT_SUMMARY" >> "$ARCHIVE_FILE"
fi

# 3. Read compaction epoch from file (written by PreCompact Python hook)
COMPACTION_EPOCH=""
if [[ -n "$CWD" && -f "$CWD/.compaction_epoch" ]]; then
  COMPACTION_EPOCH=$(cat "$CWD/.compaction_epoch" 2>/dev/null || echo "")
fi

# 4. Produce compaction.completed bus event (always)
# The manager's bus consumer handles conditional "done" SMS notification
# based on whether the user messaged during compaction.
if [[ -n "$SESSION_NAME" ]]; then
  EPOCH_FIELD=""
  if [[ -n "$COMPACTION_EPOCH" ]]; then
    EPOCH_FIELD=",\"compaction_epoch\":$COMPACTION_EPOCH"
  fi
  uv run "$HOME_DIR/dispatch/bus/cli.py" produce system \
    "{\"session_name\":\"$SESSION_NAME\",\"chat_id\":\"$CHAT_ID\",\"session_id\":\"$SESSION_ID\"$EPOCH_FIELD}" \
    --type compaction.completed \
    --key "$SESSION_NAME" \
    --source compaction \
    2>/dev/null || true

  # 5. Inject "continue" prompt so session resumes after compaction.
  # Without this, the session stops after compaction because the ResultMessage
  # ends the current turn and the queue is empty — session waits for user input.
  # Build the reply command based on backend, matching what wrap_sms() does.
  case "$SOURCE" in
    imessage|signal)
      REPLY_CMD='~/.claude/skills/sms-assistant/scripts/reply "message"'
      ;;
    dispatch-app|sven-app)
      REPLY_CMD="~/.claude/skills/dispatch-app/scripts/reply-app \"$CHAT_ID\" \"message\""
      ;;
    dispatch-api)
      REPLY_CMD="~/.claude/skills/dispatch-app/scripts/reply-dispatch-api \"$CHAT_ID\" \"message\""
      ;;
    discord)
      REPLY_CMD="~/.claude/skills/discord/scripts/send-discord \"$CHAT_ID\" \"message\""
      ;;
    *)
      REPLY_CMD='~/.claude/skills/sms-assistant/scripts/reply "message"'
      ;;
  esac

  # Build skill read hint for sms backends
  SKILL_HINT=""
  if [[ "$SOURCE" == "imessage" || "$SOURCE" == "signal" ]]; then
    SKILL_HINT="Re-read ~/.claude/skills/sms-assistant/${SOURCE}.md for backend-specific rules (tapback, reply commands, etc.)."$'\n'
  fi

  "$HOME_DIR/dispatch/bin/claude-assistant" inject-prompt "$SESSION_NAME" --admin \
    "Context was just compacted. If you were mid-task, continue where you left off. If you owe the user a reply, send it now.
${SKILL_HINT}**Important:** You are in a text message session. Communicate back with: $REPLY_CMD" \
    2>/dev/null &
fi
