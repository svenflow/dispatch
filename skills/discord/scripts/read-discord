#!/usr/bin/env -S uv run --script
# /// script
# requires-python = ">=3.12"
# dependencies = ["httpx"]
# ///
"""
read-discord - Read recent messages from a Discord channel

Usage:
    read-discord <channel_id>                  # Last 25 messages (default)
    read-discord <channel_id> --limit 50       # Last 50 messages
    read-discord <channel_id> --before <id>    # Messages before a specific message ID
    read-discord <channel_id> --after <id>     # Messages after a specific message ID
    read-discord <channel_id> --around <id>    # Messages around a specific message ID
"""
import sys
import os
import subprocess
import argparse
from datetime import datetime, timezone

import httpx

DISCORD_API = "https://discord.com/api/v10"


def get_token() -> str:
    """Get Discord bot token from keychain (primary), then env var, then secrets file."""
    try:
        result = subprocess.run(
            ["security", "find-generic-password", "-s", "discord_bot_token", "-w"],
            capture_output=True, text=True
        )
        if result.returncode == 0 and result.stdout.strip():
            return result.stdout.strip()
    except Exception:
        pass

    token = os.environ.get("DISCORD_BOT_TOKEN")
    if token:
        return token

    secrets_path = os.path.expanduser("~/.claude/secrets.env")
    if os.path.exists(secrets_path):
        for line in open(secrets_path):
            if line.startswith("DISCORD_BOT_TOKEN="):
                return line.strip().split("=", 1)[1].strip('"').strip("'")

    print("Error: DISCORD_BOT_TOKEN not found in keychain, env, or secrets", file=sys.stderr)
    sys.exit(1)


def snowflake_to_datetime(snowflake_id: int) -> datetime:
    """Convert Discord snowflake ID to datetime."""
    DISCORD_EPOCH = 1420070400000  # 2015-01-01T00:00:00Z in ms
    timestamp_ms = (snowflake_id >> 22) + DISCORD_EPOCH
    return datetime.fromtimestamp(timestamp_ms / 1000, tz=timezone.utc)


def format_message(msg: dict) -> str:
    """Format a Discord message for display."""
    author = msg.get("author", {})
    display_name = author.get("global_name") or author.get("username", "Unknown")
    content = msg.get("content", "")
    msg_id = msg.get("id", "")
    timestamp = snowflake_to_datetime(int(msg_id)) if msg_id else None

    time_str = ""
    if timestamp:
        local_time = timestamp.astimezone()
        time_str = local_time.strftime("%Y-%m-%d %I:%M:%S %p")

    attachments = msg.get("attachments", [])
    attachment_str = ""
    if attachments:
        att_names = [a.get("filename", "file") for a in attachments]
        attachment_str = f" [attachments: {', '.join(att_names)}]"

    embeds = msg.get("embeds", [])
    embed_str = ""
    if embeds:
        embed_str = f" [embeds: {len(embeds)}]"

    reply_str = ""
    ref = msg.get("referenced_message")
    if ref:
        ref_author = ref.get("author", {}).get("global_name") or ref.get("author", {}).get("username", "?")
        ref_content = ref.get("content", "")[:60]
        if len(ref.get("content", "")) > 60:
            reply_str = f' (replying to {ref_author}: "{ref_content}...")'
        else:
            reply_str = f' (replying to {ref_author}: "{ref_content}")'

    return f"[{time_str}] {display_name}{reply_str}: {content}{attachment_str}{embed_str}"


def main():
    parser = argparse.ArgumentParser(description="Read recent messages from a Discord channel")
    parser.add_argument("channel_id", help="Discord channel ID")
    parser.add_argument("--limit", "-n", type=int, default=25, help="Number of messages to fetch (max 100)")
    parser.add_argument("--before", help="Get messages before this message ID")
    parser.add_argument("--after", help="Get messages after this message ID")
    parser.add_argument("--around", help="Get messages around this message ID")
    parser.add_argument("--json", action="store_true", help="Output raw JSON")
    args = parser.parse_args()

    token = get_token()
    limit = min(args.limit, 100)

    params = {"limit": limit}
    if args.before:
        params["before"] = args.before
    if args.after:
        params["after"] = args.after
    if args.around:
        params["around"] = args.around

    headers = {"Authorization": f"Bot {token}"}

    resp = httpx.get(
        f"{DISCORD_API}/channels/{args.channel_id}/messages",
        headers=headers,
        params=params,
        timeout=15.0,
    )

    if resp.status_code != 200:
        print(f"Error: {resp.status_code} {resp.text}", file=sys.stderr)
        sys.exit(1)

    messages = resp.json()

    if args.json:
        import json
        print(json.dumps(messages, indent=2))
        return

    if not messages:
        print("No messages found.")
        return

    messages.reverse()

    print(f"--- #{args.channel_id} — last {len(messages)} messages ---\n")

    for msg in messages:
        print(format_message(msg))

    print(f"\n--- end ({len(messages)} messages) ---")


if __name__ == "__main__":
    main()
