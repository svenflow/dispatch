#!/usr/bin/env -S uv run --script
# /// script
# requires-python = ">=3.11"
# dependencies = [
#     "httpx",
# ]
# ///
"""
Fetch full listing details from Redfin/Zillow via Chrome.
Returns raw text for agent-based field extraction.

Usage:
    listing-details <url>
    listing-details --json <url>  # Return structured JSON if possible

Examples:
    listing-details "https://www.redfin.com/VT/Wilmington/156-W-Lake-Rd-05363/home/91270801"
    listing-details "https://www.zillow.com/homedetails/123-Main-St/12345_zpid/"
"""

import subprocess
import sys
import json
import re
import time

CHROME_CLI = "/Users/sven/.claude/skills/chrome-control/scripts/chrome"


def run_chrome(cmd: list[str]) -> str:
    """Run chrome CLI command and return output."""
    result = subprocess.run(
        [CHROME_CLI] + cmd,
        capture_output=True,
        text=True
    )
    if result.returncode != 0:
        raise RuntimeError(f"Chrome CLI failed: {result.stderr}")
    return result.stdout.strip()


def get_listing_text(url: str) -> str:
    """Open listing URL in Chrome and extract full text."""
    # Open the URL
    output = run_chrome(["open", url])

    # Parse tab ID from output
    tab_id = None
    for line in output.split('\n'):
        if 'id:' in line.lower():
            match = re.search(r'id[:\s]+(\d+)', line, re.IGNORECASE)
            if match:
                tab_id = match.group(1)
                break

    if not tab_id:
        # Try to find active tab
        tabs_output = run_chrome(["tabs"])
        for line in tabs_output.split('\n'):
            if url.split('/')[2] in line:  # Match domain
                match = re.search(r'\[(\d+)\]', line)
                if match:
                    tab_id = match.group(1)
                    break

    if not tab_id:
        raise RuntimeError("Could not find tab ID")

    # Wait for page to load
    time.sleep(3)

    # Extract text from the page
    text = run_chrome(["text", tab_id])

    return text


def extract_key_fields(text: str) -> dict:
    """Extract key fields from listing text using regex patterns.

    This is a best-effort extraction. The agent can do better parsing
    of the raw text for complex fields.
    """
    fields = {}

    # Price
    price_match = re.search(r'\$[\d,]+(?:,\d{3})*', text)
    if price_match:
        fields['price'] = price_match.group(0)

    # Beds/Baths
    beds_match = re.search(r'(\d+)\s*(?:bed|bd|bedroom)', text, re.I)
    if beds_match:
        fields['beds'] = int(beds_match.group(1))

    baths_match = re.search(r'(\d+(?:\.\d+)?)\s*(?:bath|ba|bathroom)', text, re.I)
    if baths_match:
        fields['baths'] = float(baths_match.group(1))

    # Sqft
    sqft_match = re.search(r'([\d,]+)\s*(?:sq\s*ft|sqft|square feet)', text, re.I)
    if sqft_match:
        fields['sqft'] = int(sqft_match.group(1).replace(',', ''))

    # Acres
    acres_match = re.search(r'([\d.]+)\s*(?:acres?|ac)', text, re.I)
    if acres_match:
        fields['lot_acres'] = float(acres_match.group(1))

    # Year built
    year_match = re.search(r'(?:built|year built|constructed)[:\s]*(\d{4})', text, re.I)
    if year_match:
        fields['year_built'] = int(year_match.group(1))

    # Heating
    heating_patterns = [
        r'(?:heating|heat)[:\s]*([^,\n]+)',
        r'(forced air|baseboard|radiant|oil|propane|gas|electric|wood stove)',
    ]
    for pattern in heating_patterns:
        match = re.search(pattern, text, re.I)
        if match:
            fields['heating'] = match.group(1).strip()
            break

    # Water/Well/Septic
    if re.search(r'\bwell\b', text, re.I):
        fields['water_source'] = 'well'
    elif re.search(r'\b(?:city water|public water|municipal water)\b', text, re.I):
        fields['water_source'] = 'city'

    if re.search(r'\bseptic\b', text, re.I):
        fields['sewer'] = 'septic'
    elif re.search(r'\b(?:city sewer|public sewer|municipal sewer)\b', text, re.I):
        fields['sewer'] = 'city'

    # Days on market
    dom_match = re.search(r'(\d+)\s*days?\s*(?:on market|on redfin|on zillow|listed)', text, re.I)
    if dom_match:
        fields['days_on_market'] = int(dom_match.group(1))

    return fields


def main():
    args = sys.argv[1:]

    if not args or args[0] in ['-h', '--help']:
        print(__doc__)
        sys.exit(0)

    json_output = False
    url = None

    for arg in args:
        if arg == '--json':
            json_output = True
        elif arg.startswith('http'):
            url = arg

    if not url:
        print("Error: URL required", file=sys.stderr)
        sys.exit(1)

    try:
        text = get_listing_text(url)

        if json_output:
            fields = extract_key_fields(text)
            fields['raw_text'] = text[:5000]  # Truncate raw text for JSON
            fields['source_url'] = url
            print(json.dumps(fields, indent=2))
        else:
            print(text)

    except Exception as e:
        print(f"Error: {e}", file=sys.stderr)
        sys.exit(1)


if __name__ == "__main__":
    main()
