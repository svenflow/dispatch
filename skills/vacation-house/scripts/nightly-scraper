def log(msg: str):
    """Log to stdout and logfile."""
    ts = datetime.now().strftime("%Y-%m-%d %H:%M:%S")
    line = f"[{ts}] {msg}"
    print(line, file=sys.stderr)
    LOG_DIR.mkdir(parents=True, exist_ok=True)
    with open(LOG_DIR / "nightly-scraper.log", "a") as f:
        f.write(line + "\n")


def enrich_ski_distances(listings: list[dict]) -> list[dict]:
    """Ensure every listing has ski driving distances.

    For listings missing ski_driving data, use goplaces to find
    nearby ski mountains and calculate driving distances.
    Killington is always included as primary reference.
    """
    # Vermont ski mountains with known addresses for distance calc
    VT_SKI_MOUNTAINS = [
        "Killington Resort, Killington, VT",
        "Sugarbush Resort, Warren, VT",
        "Stowe Mountain Resort, Stowe, VT",
        "Okemo Mountain Resort, Ludlow, VT",
        "Stratton Mountain Resort, Stratton, VT",
        "Mount Snow, West Dover, VT",
        "Jay Peak Resort, Jay, VT",
        "Burke Mountain, East Burke, VT",
        "Mad River Glen, Fayston, VT",
    ]

    for listing in listings:
        if listing.get("ski_driving") and len(listing["ski_driving"]) >= 2:
            continue  # Already has ski data

        address = listing.get("address", "")
        if not address:
            continue

        log(f"  SKI ENRICHMENT: Calculating ski distances for {address}")
        ski_drives = []

        # Get API key from keychain
        try:
            api_key_result = subprocess.run(
                ["security", "find-generic-password", "-s", "google-api-key", "-w"],
                capture_output=True, text=True, timeout=5
            )
            api_key = api_key_result.stdout.strip() if api_key_result.returncode == 0 else ""
        except:
            api_key = ""

        env = {**os.environ, "GOOGLE_PLACES_API_KEY": api_key} if api_key else os.environ

        # Use goplaces directions for driving distances to ski mountains
        for mountain_addr in VT_SKI_MOUNTAINS:
            mountain_name = mountain_addr.split(",")[0].strip()
            try:
                result = subprocess.run(
                    ["goplaces", "directions",
                     "--from", address,
                     "--to", mountain_addr,
                     "--mode", "drive",
                     "--units", "imperial",
                     "--json"],
                    capture_output=True, text=True, timeout=15,
                    env=env
                )
                if result.returncode == 0:
                    data = json.loads(result.stdout)
                    duration_secs = data.get("duration_seconds", 0)
                    distance_meters = data.get("distance_meters", 0)
                    drive_mins = duration_secs / 60
                    drive_miles = distance_meters / 1609.34
                    ski_drives.append({
                        "name": mountain_name,
                        "drive_minutes": int(drive_mins),
                        "drive_miles": round(drive_miles, 1),
                    })
            except Exception as e:
                log(f"    Failed distance to {mountain_name}: {e}")
                continue

            # Stop after finding 3 mountains to limit API calls
            if len(ski_drives) >= 3:
                break

        if ski_drives:
            # Sort by drive time, Killington always first if present
            ski_drives.sort(key=lambda x: (
                0 if "Killington" in x["name"] else 1,
                x["drive_minutes"]
            ))
            listing["ski_driving"] = ski_drives[:3]
            summary = ', '.join(f'{s["name"]} {s["drive_minutes"]}min' for s in ski_drives[:3])
            log(f"    Found: {summary}")
        else:
            # Fallback: at minimum show Killington
            listing["ski_driving"] = [{"name": "Killington Resort", "drive_minutes": -1, "drive_miles": -1}]
            log(f"    Could not calculate ski distances")

    return listings


VCGI_CACHE_PROXY = "https://vcgi-cache-proxy.nicklaudethorat.workers.dev"
TILE_PROXY = "https://sven-plot-proxy.nicklaudethorat.workers.dev"


def enrich_parcel_data(listings: list[dict]) -> list[dict]:
    """Enrich listings with VCGI parcel data (geometry, assessed values, owner, acreage)."""
    import urllib.request
    import urllib.parse

    for listing in listings:
        if listing.get("vcgi_geometry"):
            continue  # Already has parcel data

        lat = listing.get("lat")
        lon = listing.get("lon") or listing.get("lng")

        if not lat or not lon:
            log(f"  PARCEL: Skipping {listing.get('address', '?')} — no lat/lon")
            continue

        address = listing.get("address", "?")
        log(f"  PARCEL: Looking up parcel for {address} ({lat}, {lon})")

        try:
            url = f"{VCGI_CACHE_PROXY}/parcel?lat={lat}&lng={lon}"
            req = urllib.request.Request(url, headers={"User-Agent": "nightly-scraper/1.0"})
            with urllib.request.urlopen(req, timeout=15) as resp:
                data = json.loads(resp.read().decode())

            if data.get("features") and len(data["features"]) > 0:
                feature = data["features"][0]
                props = feature.get("properties", {})
                geom = feature.get("geometry")

                listing["vcgi_span"] = props.get("SPAN", "")
                listing["vcgi_owner"] = props.get("OWNER1", "")
                listing["vcgi_acres"] = props.get("ACRESGL")
                listing["vcgi_land_value"] = props.get("LAND_LV")
                listing["vcgi_improvement_value"] = props.get("IMPRV_LV")
                listing["vcgi_total_value"] = props.get("REAL_FLV")
                listing["vcgi_town"] = props.get("TNAME", "")
                listing["vcgi_property_type"] = props.get("PROPTYPE", "")

                if geom:
                    listing["vcgi_geometry"] = json.dumps(geom)

                log(f"    Found: SPAN={listing['vcgi_span']}, {listing.get('vcgi_acres', '?')} acres, assessed ${listing.get('vcgi_total_value', '?'):,}")
            else:
                log(f"    No parcel found at coordinates")
        except Exception as e:
            log(f"    PARCEL error: {e}")

    return listings


def run_unified_search() -> list[dict]:
    """Run unified-search and return listings as JSON."""
    log("DISCOVERY: Running unified-search across VT sources...")
    cmd = [
        str(SCRIPTS_DIR / "unified-search"),
        "search",
        "--beds", str(SEARCH_CRITERIA["beds"]),
        "--max-price", str(SEARCH_CRITERIA["max_price"]),
        "--home", "7 Eastburn St, Brighton, MA",
        "--json",
        "--top", "50",
    ]
    try:
        result = subprocess.run(
            cmd, capture_output=True, text=True, timeout=300
        )
        if result.returncode != 0:
            log(f"unified-search failed: {result.stderr[:500]}")
            return []

        # Parse JSON from stdout (skip any non-JSON lines)
        for line in result.stdout.strip().split("\n"):
            line = line.strip()
            if line.startswith("["):
                listings = json.loads(line)
                log(f"DISCOVERY: Found {len(listings)} listings")
                return listings

        # Try parsing entire output
        listings = json.loads(result.stdout.strip())
        log(f"DISCOVERY: Found {len(listings)} listings")
        return listings
    except json.JSONDecodeError as e:
        log(f"Failed to parse unified-search JSON: {e}")
        # Try to find JSON array in output
        try:
            start = result.stdout.index("[")
            end = result.stdout.rindex("]") + 1
            listings = json.loads(result.stdout[start:end])
            log(f"DISCOVERY: Found {len(listings)} listings (extracted from output)")
            return listings
        except (ValueError, json.JSONDecodeError):
            log(f"Could not extract JSON from output: {result.stdout[:200]}")
            return []
    except subprocess.TimeoutExpired:
        log("unified-search timed out after 5 minutes")
        return []
    except Exception as e:
        log(f"unified-search error: {e}")
        return []


def get_existing_addresses() -> set[str]:
    """Fetch all known addresses from D1 to dedupe."""
    log("DEDUPE: Fetching existing listings from D1...")
    try:
        import requests
        resp = requests.get(
            f"{LISTINGS_API}/listings",
            params={"limit": 1000, "status": "active"},
            timeout=15,
        )
        if resp.status_code == 200:
            data = resp.json()
            listings = data if isinstance(data, list) else data.get("listings", [])
            addresses = {normalize_address(l["address"]) for l in listings if l.get("address")}
            log(f"DEDUPE: {len(addresses)} existing listings in D1")
            return addresses
        else:
            log(f"D1 fetch failed: {resp.status_code}")
            return set()
    except Exception as e:
        log(f"D1 fetch error: {e}")
        return set()


def normalize_address(addr: str) -> str:
    """Normalize address for comparison, including common abbreviations."""
    addr = addr.lower().strip().replace(",", "").replace(".", "")
    # Normalize common street suffix abbreviations
    replacements = [
        (" road", " rd"), (" street", " st"), (" avenue", " ave"),
        (" lane", " ln"), (" drive", " dr"), (" court", " ct"),
        (" circle", " cir"), (" boulevard", " blvd"), (" place", " pl"),
        (" route", " rte"), (" highway", " hwy"),
    ]
    for full, abbr in replacements:
        addr = addr.replace(full, abbr)
    return addr


def sync_to_d1(listings: list[dict]) -> dict:
    """Bulk upsert listings to D1. Returns {created, updated}."""
    if not listings:
        return {"created": 0, "updated": 0}

    log(f"SYNC: Uploading {len(listings)} listings to D1...")
    import requests

    # Map unified-search fields to D1 schema
    d1_listings = []
    for l in listings:
        d1_listings.append({
            "address": l.get("address", ""),
            "city": l.get("city", ""),
            "state": l.get("state", ""),
            "price": l.get("price"),
            "beds": l.get("beds"),
            "baths": l.get("baths"),
            "sqft": l.get("sqft"),
            "lot_acres": l.get("acres"),
            "primary_image_url": l.get("image_url"),
            "source": l.get("source", ""),
            "source_url": l.get("url", ""),
            "status": "active",
            "extra_data": json.dumps({
                "score": l.get("score"),
                "nearest_ski": l.get("nearest_ski"),
                "drive_from_home": l.get("drive_from_home"),
                "ski_driving": l.get("ski_driving"),
            }),
        })

    try:
        resp = requests.post(
            f"{LISTINGS_API}/listings/bulk",
            json={"listings": d1_listings},
            timeout=30,
        )
        if resp.status_code == 200:
            result = resp.json()
            log(f"SYNC: Created {result.get('created', 0)}, Updated {result.get('updated', 0)}")
            return result
        else:
            log(f"SYNC failed: {resp.status_code} {resp.text[:200]}")
            return {"created": 0, "updated": 0}
    except Exception as e:
        log(f"SYNC error: {e}")
        return {"created": 0, "updated": 0}


def filter_new_listings(listings: list[dict], existing: set[str]) -> list[dict]:
    """Filter to only listings not already in D1."""
    new = []
    for l in listings:
        addr = normalize_address(l.get("address", ""))
        if addr and addr not in existing:
            new.append(l)
    log(f"DEDUPE: {len(new)} new listings (out of {len(listings)} total)")
    return new


def get_google_places_api_key() -> str:
    """Fetch Google Places API key from macOS keychain."""
    try:
        result = subprocess.run(
            ["security", "find-generic-password", "-s", "google-api-key", "-w"],
            capture_output=True, text=True, timeout=10,
        )
        if result.returncode == 0:
            return result.stdout.strip()
        log("WARNING: Could not fetch Google Places API key from keychain")
        return ""
    except Exception as e:
        log(f"WARNING: Keychain access failed: {e}")
        return ""


def enrich_listing(listing: dict) -> dict:
    """Use scrapling (webfetch) to scrape listing page for details (acres, description, style, etc.)."""
    address = listing.get("address", "")
    url = listing.get("url", "")
    if not address or not url:
        return listing

    WEBFETCH = str(Path.home() / ".claude/skills/webfetch/scripts/webfetch")

    # Step 1: Scrape the listing page with webfetch (scrapling)
    scraped_text = ""
    try:
        result = subprocess.run(
            [WEBFETCH, url, "--tier", "1", "--timeout", "20"],
            capture_output=True, text=True, timeout=30,
        )
        if result.returncode == 0 and result.stdout.strip():
            scraped_text = result.stdout.strip()
        else:
            # Try tier 2 (stealthy) as fallback
            log(f"ENRICH: Tier 1 failed for {address}, trying tier 2...")
            result = subprocess.run(
                [WEBFETCH, url, "--tier", "2", "--timeout", "30"],
                capture_output=True, text=True, timeout=45,
            )
            if result.returncode == 0 and result.stdout.strip():
                scraped_text = result.stdout.strip()
    except subprocess.TimeoutExpired:
        log(f"ENRICH: webfetch timeout for {address}")
    except Exception as e:
        log(f"ENRICH: webfetch error for {address}: {e}")

    if not scraped_text or len(scraped_text) < 200:
        log(f"ENRICH: No content scraped for {address}")
        return listing

    # Cache scraped text for verification (avoid re-scraping)
    listing["_scraped_text"] = scraped_text

    # Step 2: Parse the scraped text with claude (opus call, no web search needed)
    # Truncate to avoid token limits — listing details are usually in the first ~4000 chars
    text_for_parsing = scraped_text[:6000]

    parse_prompt = (
        f"Extract property details from this real estate listing text. "
        f'Return ONLY a JSON object with fields: "acres" (number or null), '
        f'"year_built" (number or null), "construction_style" (string like "log cabin", "farmhouse", "colonial", "modern", "post-and-beam" or null), '
        f'"water_features" (string describing any pond, lake, stream, waterfall, river, or null), '
        f'"heating" (string like "forced hot air", "radiant", "wood stove", "oil", "propane" or null), '
        f'"description_summary" (2-3 sentence summary of the property character and setting, or null). '
        f"Listing text:\n\n{text_for_parsing}"
    )

    try:
        result = subprocess.run(
            ["claude", "-p", parse_prompt, "--output-format", "json", "--model", "opus"],
            capture_output=True, text=True, timeout=30,
        )
        if result.returncode != 0:
            log(f"ENRICH: parse failed for {address}: {result.stderr[:200]}")
            return listing

        cli_output = json.loads(result.stdout)
        text = cli_output.get("result", "").strip()

        # Handle potential markdown wrapping
        if text.startswith("```"):
            text = text.split("\n", 1)[1].rsplit("```", 1)[0].strip()

        enrichment = json.loads(text)

        # Merge enrichment data into listing (don't overwrite existing non-null values)
        for key in ["acres", "year_built", "construction_style", "water_features", "heating", "description_summary"]:
            val = enrichment.get(key)
            if val is not None:
                if key == "acres" and listing.get("acres") and listing["acres"] != "?":
                    listing.setdefault("enriched_acres", val)
                else:
                    listing[key] = val

        log(f"ENRICH: {address} — style={enrichment.get('construction_style', '?')}, acres={enrichment.get('acres', '?')}, water={enrichment.get('water_features', '?')}")
        return listing
    except json.JSONDecodeError as e:
        log(f"ENRICH: JSON parse failed for {address}: {e}")
        return listing
    except subprocess.TimeoutExpired:
        log(f"ENRICH: parse timeout for {address}")
        return listing
    except Exception as e:
        log(f"ENRICH: Error for {address}: {e}")
        return listing


def check_nearby(listing: dict, api_key: str) -> dict:
    """Use goplaces CLI to check for nearby points of interest (fire stations, airports, etc.)."""
    address = listing.get("address", "")
    city = listing.get("city", "")
    state = listing.get("state", "")
    if not address:
        return listing

    good_to_know = []
    env = {**os.environ, "GOOGLE_PLACES_API_KEY": api_key}
    full_address = f"{address}, {city}, {state}".strip(", ")

    # State abbreviation for filtering wrong-state results
    state_abbr = (state or "").upper().strip()
    # Map full state names to abbreviations
    state_map = {"VERMONT": "VT", "NEW HAMPSHIRE": "NH", "MAINE": "ME",
                 "MASSACHUSETTS": "MA", "NEW YORK": "NY", "CONNECTICUT": "CT"}
    if state_abbr in state_map:
        state_abbr = state_map[state_abbr]

    # Checks to perform: (search_term, type_filter, radius_m, label)
    checks = [
        ("fire station", "fire_station", 1000, "Fire station"),
        ("airport", "airport", 10000, "Airport"),
    ]

    for search_term, place_type, radius_m, label in checks:
        try:
            # Use text search near the address since we may not have lat/lng
            result = subprocess.run(
                [
                    "goplaces", "search",
                    f"{search_term} near {full_address}",
                    "--type", place_type,
                    "--limit", "3",
                    "--json",
                ],
                capture_output=True, text=True, timeout=15, env=env,
            )
            if result.returncode != 0:
                continue

            places = json.loads(result.stdout)
            if not places:
                continue

            # places is a list of results
            place_list = places if isinstance(places, list) else places.get("places", [])
            for place in place_list[:3]:
                name = place.get("displayName", {}).get("text", "") if isinstance(place.get("displayName"), dict) else place.get("name", place.get("displayName", ""))
                addr = place.get("formattedAddress", place.get("address", ""))

                # Filter out results from wrong states (e.g., MA fire dept for ME property)
                if addr and state_abbr:
                    addr_upper = addr.upper()
                    # Check if the result is in the same state
                    wrong_state = False
                    for st in ["VT", "NH", "ME", "MA", "NY", "CT"]:
                        if f", {st} " in addr_upper or addr_upper.endswith(f", {st}"):
                            if st != state_abbr:
                                wrong_state = True
                                break
                    if wrong_state:
                        continue

                if name:
                    good_to_know.append(f"{label}: {name}" + (f" ({addr})" if addr else ""))
        except subprocess.TimeoutExpired:
            log(f"NEARBY: Timeout checking {label} for {address}")
        except Exception as e:
            log(f"NEARBY: Error checking {label} for {address}: {e}")

    if good_to_know:
        listing["good_to_know"] = good_to_know
        log(f"NEARBY: {address} — {len(good_to_know)} items found")
    else:
        listing["good_to_know"] = []
        log(f"NEARBY: {address} — nothing notable found")

    return listing


def enrich_and_check_nearby(listing: dict, api_key: str) -> dict:
    """Run enrichment and nearby check for a single listing (both steps)."""
    listing = enrich_listing(listing)
    if api_key:
        listing = check_nearby(listing, api_key)
    else:
        listing["good_to_know"] = []
    return listing


def enrich_listings(listings: list[dict], max_workers: int = 5) -> list[dict]:
    """Enrich all listings in parallel (web search + Google Places nearby)."""
    if not listings:
        return []

    log(f"ENRICHMENT: Enriching {len(listings)} listings in parallel (max {max_workers} workers)...")

    # Fetch API key once
    api_key = get_google_places_api_key()
    if not api_key:
        log("ENRICHMENT: No Google Places API key — skipping nearby checks")

    results = []
    with ThreadPoolExecutor(max_workers=max_workers) as executor:
        futures = {
            executor.submit(enrich_and_check_nearby, l, api_key): l
            for l in listings
        }
        for future in as_completed(futures):
            try:
                result = future.result()
                results.append(result)
            except Exception as e:
                listing = futures[future]
                log(f"ENRICH: Exception for {listing.get('address', '?')}: {e}")
                listing["good_to_know"] = []
                results.append(listing)

    log(f"ENRICHMENT: Complete — {len(results)} listings enriched")
    return results


def refine_listing(listing: dict) -> dict:
    """Use claude CLI to score a single listing against preferences + favorites."""
    address = listing.get("address", "Unknown")
    price = listing.get("price", "N/A")
    beds = listing.get("beds", "?")
    baths = listing.get("baths", "?")
    sqft = listing.get("sqft", "?")
    acres = listing.get("acres", "?")
    url = listing.get("url", "")
    source = listing.get("source", "")
    ski_info = listing.get("ski_driving", [])
    drive_home = listing.get("drive_from_home", {})
    image_url = listing.get("image_url", "")

    ski_text = ", ".join(
        f"{s['name']} ({s['drive_minutes']}min)" for s in ski_info[:3]
    ) if ski_info else "unknown"

    drive_text = ""
    if drive_home:
        h = drive_home.get("hours", 0)
        m = drive_home.get("minutes", 0)
        mi = drive_home.get("miles", 0)
        drive_text = f"{int(h)}hr {int(m % 60)}min ({int(mi)} mi)"

    favorites_text = "\n".join(
        f"- {f['name']}: {', '.join(f['traits'])}" for f in FAVORITES
    )

    # Enrichment data
    construction_style = listing.get("construction_style", "unknown")
    water_features = listing.get("water_features", "unknown")
    year_built = listing.get("year_built", "unknown")
    heating = listing.get("heating", "unknown")
    description_summary = listing.get("description_summary", "")
    good_to_know = listing.get("good_to_know", [])

    price_str = f"${price:,}" if isinstance(price, (int, float)) else str(price)

    # Build enrichment section
    enrichment_section = ""
    if any(v and v != "unknown" for v in [construction_style, water_features, description_summary]):
        enrichment_section = f"""
ENRICHED DETAILS (from web research):
- Construction Style: {construction_style}
- Water Features: {water_features}
- Year Built: {year_built}
- Heating: {heating}
- Description: {description_summary if description_summary else 'N/A'}
"""

    # Build good_to_know section
    nearby_section = ""
    if good_to_know:
        nearby_items = "\n".join(f"- {item}" for item in good_to_know)
        nearby_section = f"""
NEARBY POINTS OF INTEREST:
{nearby_items}
"""

    prompt = f"""You are evaluating a Vermont/NH/ME vacation property listing for Nikhil & Caroline.

PROPERTY:
- Address: {address}
- Price: {price_str}
- Beds: {beds} / Baths: {baths}
- Sqft: {sqft} / Acres: {acres}
- Source: {source}
- Ski proximity: {ski_text}
- Drive from Brighton MA: {drive_text}
- URL: {url}
{enrichment_section}
{nearby_section}
{HARD_REQUIREMENTS}

{VIBE_CRITERIA}

THEIR FAVORITE PROPERTIES (gold standard — match this energy):
{favorites_text}

Score this property 1-10 based on:
1. Hard requirement match (beds, baths, acres, ski proximity, location)
2. Vibe match (would Caroline love this? rustic, log cabin, character, water, views)
3. Similarity to their favorites (log homes, big acreage, water features, wild feel)
4. Value (price relative to what you get)
5. Nearby concerns (fire station proximity is GOOD for rural properties, airport nearby is bad)

IMPORTANT: Without seeing photos, you can only judge on specs. Be honest about what you can and can't assess. A property that meets hard requirements but has unknown vibe should score 5-6. Only score 7+ if the description strongly suggests vibe match. Score 8+ only for truly exceptional matches.

Respond in this exact JSON format ONLY (no markdown, no code blocks, no extra text):
{{"score": 7, "summary": "One sentence summary of the property", "vibe_match": "low|medium|high|unknown", "flags": ["any concerns"], "good_to_know": ["Fire station 200m away", "Near Class 4 road", etc.], "why": "2-3 sentences on why this score"}}"""

    fallback = {
        "address": address, "price": price, "beds": beds, "baths": baths,
        "acres": acres, "url": url, "image_url": image_url,
        "score": 5, "summary": "Could not evaluate", "vibe_match": "unknown",
        "flags": ["AI evaluation failed"], "good_to_know": good_to_know,
        "why": "Scoring failed, manual review needed",
        "ski_driving": ski_info, "drive_from_home": drive_home,
        "construction_style": construction_style, "water_features": water_features,
        "description_summary": description_summary,
    }

    try:
        result = subprocess.run(
            ["claude", "-p", prompt, "--output-format", "json", "--model", "opus"],
            capture_output=True, text=True, timeout=60,
        )
        if result.returncode != 0:
            log(f"REFINE: claude CLI failed for {address}: {result.stderr[:200]}")
            return fallback

        # Parse the claude CLI JSON output to get the result text
        cli_output = json.loads(result.stdout)
        text = cli_output.get("result", "").strip()

        # Handle potential markdown wrapping
        if text.startswith("```"):
            text = text.split("\n", 1)[1].rsplit("```", 1)[0].strip()

        scored = json.loads(text)
        scored["address"] = address
        scored["price"] = price
        scored["beds"] = beds
        scored["baths"] = baths
        scored["acres"] = acres
        scored["url"] = url
        scored["image_url"] = image_url
        scored["ski_driving"] = ski_info
        scored["drive_from_home"] = drive_home
        scored["construction_style"] = construction_style
        scored["water_features"] = water_features
        scored["description_summary"] = description_summary
        # Merge good_to_know from enrichment and AI response
        ai_gtk = scored.get("good_to_know", [])
        if isinstance(ai_gtk, list) and good_to_know:
            scored["good_to_know"] = list(set(good_to_know + ai_gtk))
        elif good_to_know:
            scored["good_to_know"] = good_to_know
        log(f"REFINE: {address} → score {scored['score']}/10 (vibe: {scored.get('vibe_match', '?')})")
        return scored
    except json.JSONDecodeError as e:
        log(f"REFINE: Failed to parse AI response for {address}: {e}")
        return fallback
    except subprocess.TimeoutExpired:
        log(f"REFINE: Timeout evaluating {address}")
        return fallback
    except Exception as e:
        log(f"REFINE: Error evaluating {address}: {e}")
        fallback["flags"] = [str(e)]
        return fallback


def refine_listings(listings: list[dict], max_workers: int = 5) -> list[dict]:
    """Score all listings in parallel using AI refinement."""
    if not listings:
        return []

    log(f"REFINEMENT: Scoring {len(listings)} listings in parallel (max {max_workers} workers)...")
    results = []

    with ThreadPoolExecutor(max_workers=max_workers) as executor:
        futures = {executor.submit(refine_listing, l): l for l in listings}
        for future in as_completed(futures):
            try:
                result = future.result()
                results.append(result)
            except Exception as e:
                listing = futures[future]
                log(f"REFINE: Exception for {listing.get('address', '?')}: {e}")

    results.sort(key=lambda x: x.get("score", 0), reverse=True)
    return results


def verify_listing(listing: dict) -> dict:
    """Verify enriched data against source text to catch hallucinations."""
    address = listing.get("address", "Unknown")
    score = listing.get("score", 0)
    url = listing.get("url", "")

    # Only verify listings scoring 4+
    if score < 4:
        listing["verified"] = None
        listing["verification_notes"] = ["Score below threshold, skipped verification"]
        return listing

    # Use cached scraped text from enrichment (avoid re-scraping)
    scraped_text = listing.get("_scraped_text", "")

    # Only re-scrape if no cached text
    if not scraped_text and url:
        WEBFETCH = str(Path.home() / ".claude/skills/webfetch/scripts/webfetch")
        try:
            result = subprocess.run(
                [WEBFETCH, url, "--tier", "1", "--timeout", "20"],
                capture_output=True, text=True, timeout=30,
            )
            if result.returncode == 0 and result.stdout.strip():
                scraped_text = result.stdout.strip()
            else:
                result = subprocess.run(
                    [WEBFETCH, url, "--tier", "2", "--timeout", "30"],
                    capture_output=True, text=True, timeout=45,
                )
                if result.returncode == 0 and result.stdout.strip():
                    scraped_text = result.stdout.strip()
        except subprocess.TimeoutExpired:
            log(f"VERIFY: webfetch timeout for {address}")
        except Exception as e:
            log(f"VERIFY: webfetch error for {address}: {e}")

    # If source text couldn't be scraped, mark as unverifiable
    if not scraped_text or len(scraped_text) < 100:
        listing["verified"] = None
        listing["verification_notes"] = ["Could not scrape source text for verification"]
        log(f"VERIFY: {address} — unverifiable (no source text)")
        return listing

    # Build verification prompt
    acres = listing.get("acres", "unknown")
    construction_style = listing.get("construction_style", "unknown")
    water_features = listing.get("water_features", "unknown")
    year_built = listing.get("year_built", "unknown")
    description_summary = listing.get("description_summary", "")

    verify_prompt = (
        f"Verify these enriched property details against the source listing text. "
        f"Check if each field is accurate.\n\n"
        f"ENRICHED DATA:\n"
        f"- Acres: {acres}\n"
        f"- Construction: {construction_style}\n"
        f"- Water: {water_features}\n"
        f"- Year Built: {year_built}\n"
        f"- Description: {description_summary}\n\n"
        f"SOURCE TEXT:\n"
        f"{scraped_text[:4000]}\n\n"
        f'Return JSON: {{"verified": true/false, "corrections": {{"field": "corrected_value"}}, "notes": ["what was wrong"]}}'
    )

    try:
        result = subprocess.run(
            ["claude", "-p", verify_prompt, "--output-format", "json", "--model", "opus"],
            capture_output=True, text=True, timeout=60,
        )
        if result.returncode != 0:
            log(f"VERIFY: claude CLI failed for {address}: {result.stderr[:200]}")
            listing["verified"] = None
            listing["verification_notes"] = ["Verification call failed"]
            return listing

        cli_output = json.loads(result.stdout)
        text = cli_output.get("result", "").strip()

        if not text:
            log(f"VERIFY: Empty result from claude CLI for {address}")
            listing["verified"] = None
            listing["verification_notes"] = ["Verification returned empty result"]
            return listing

        # Handle potential markdown wrapping
        if text.startswith("```"):
            text = text.split("\n", 1)[1].rsplit("```", 1)[0].strip()

        # Try to extract JSON from text if it contains other content
        if not text.startswith("{"):
            import re
            json_match = re.search(r'\{.*\}', text, re.DOTALL)
            if json_match:
                text = json_match.group()
            else:
                log(f"VERIFY: No JSON found in response for {address}: {text[:100]}")
                listing["verified"] = None
                listing["verification_notes"] = ["No JSON in verification response"]
                return listing

        verification = json.loads(text)
        is_verified = verification.get("verified", False)
        corrections = verification.get("corrections", {})
        notes = verification.get("notes", [])

        listing["verified"] = is_verified
        listing["verification_notes"] = notes if notes else []

        if not is_verified:
            # Downgrade score by 2 points
            original_score = listing.get("score", 0)
            listing["score"] = max(1, original_score - 2)
            listing.setdefault("flags", []).append("verification_failed")
            log(f"VERIFY: {address} — FAILED (score {original_score} → {listing['score']}). Notes: {notes}")

            # Apply corrections to the listing
            for field, corrected_value in corrections.items():
                if field in ("acres", "construction_style", "water_features", "year_built", "description_summary"):
                    listing[field] = corrected_value
                    log(f"VERIFY: {address} — corrected {field} → {corrected_value}")
        else:
            log(f"VERIFY: {address} — PASSED")

        return listing
    except json.JSONDecodeError as e:
        log(f"VERIFY: JSON parse failed for {address}: {e}")
        listing["verified"] = None
        listing["verification_notes"] = ["Verification parse error"]
        return listing
    except subprocess.TimeoutExpired:
        log(f"VERIFY: timeout for {address}")
        listing["verified"] = None
        listing["verification_notes"] = ["Verification timed out"]
        return listing
    except Exception as e:
        log(f"VERIFY: Error for {address}: {e}")
        listing["verified"] = None
        listing["verification_notes"] = [f"Verification error: {e}"]
        return listing


def verify_listings(listings: list[dict], max_workers: int = 5) -> list[dict]:
    """Verify all listings scoring 4+ in parallel."""
    if not listings:
        return []

    to_verify = [l for l in listings if l.get("score", 0) >= 4]
    skip = [l for l in listings if l.get("score", 0) < 4]

    # Mark skipped listings
    for l in skip:
        l["verified"] = None
        l["verification_notes"] = ["Score below threshold, skipped verification"]

    if not to_verify:
        log("VERIFICATION: No listings scoring 4+ to verify")
        return listings

    log(f"VERIFICATION: Verifying {len(to_verify)} listings scoring 4+ (max {max_workers} workers)...")
    verified_results = []

    with ThreadPoolExecutor(max_workers=max_workers) as executor:
        futures = {executor.submit(verify_listing, l): l for l in to_verify}
        for future in as_completed(futures):
            try:
                result = future.result()
                verified_results.append(result)
            except Exception as e:
                listing = futures[future]
                log(f"VERIFY: Exception for {listing.get('address', '?')}: {e}")
                listing["verified"] = None
                listing["verification_notes"] = [f"Exception: {e}"]
                verified_results.append(listing)

    all_results = verified_results + skip
    all_results.sort(key=lambda x: x.get("score", 0), reverse=True)

    passed = sum(1 for l in all_results if l.get("verified") is True)
    failed = sum(1 for l in all_results if l.get("verified") is False)
    unverifiable = sum(1 for l in all_results if l.get("verified") is None)
    log(f"VERIFICATION: Complete — {passed} passed, {failed} failed, {unverifiable} unverifiable")

    return all_results


def save_archive(results: list[dict], all_listings: list[dict]):
    """Save search results to daily archive."""
    today = date.today().isoformat()
    archive_dir = ARCHIVES_DIR / today
    archive_dir.mkdir(parents=True, exist_ok=True)

    archive_file = archive_dir / "nightly-scraper-results.md"
    lines = [
        f"# Nightly Scraper Results — {today}",
        f"",
        f"Total listings scanned: {len(all_listings)}",
        f"New listings found: {len(results)}",
        f"",
    ]

    if results:
        lines.append("## Scored Listings (by AI refinement)")
        lines.append("")
        for i, r in enumerate(results, 1):
            drive = r.get("drive_from_home", {})
            drive_text = ""
            if drive:
                h = drive.get("hours", 0)
                m = drive.get("minutes", 0)
                mi = drive.get("miles", 0)
                drive_text = f"{int(h)}hr {int(m % 60)}min ({int(mi)} mi)"

            ski_text = ", ".join(
                f"{s['name']} ({s['drive_minutes']}min)"
                for s in r.get("ski_driving", [])[:2]
            ) if r.get("ski_driving") else "?"

            price = r.get("price", "?")
            price_str = f"${price:,}" if isinstance(price, (int, float)) else str(price)

            verified = r.get("verified")
            v_icon = "✅" if verified is True else "⚠️" if verified is False else "❓"
            lines.append(f"### {i}. {r.get('address', '?')} — Score: {r.get('score', '?')}/10 {v_icon}")
            lines.append(f"- **Price:** {price_str}")
            lines.append(f"- **Beds/Baths:** {r.get('beds', '?')}/{r.get('baths', '?')}")
            lines.append(f"- **Acres:** {r.get('acres', '?')}")
            lines.append(f"- **Vibe Match:** {r.get('vibe_match', '?')}")
            lines.append(f"- **Drive from Brighton:** {drive_text}")
            lines.append(f"- **Ski:** {ski_text}")
            if r.get("construction_style") and r["construction_style"] != "unknown":
                lines.append(f"- **Style:** {r['construction_style']}")
            if r.get("water_features") and r["water_features"] != "unknown":
                lines.append(f"- **Water:** {r['water_features']}")
            if r.get("description_summary"):
                lines.append(f"- **Description:** {r['description_summary']}")
            lines.append(f"- **Link:** {r.get('url', 'N/A')}")
            lines.append(f"- **Summary:** {r.get('summary', 'N/A')}")
            lines.append(f"- **Why:** {r.get('why', 'N/A')}")
            if r.get("flags"):
                lines.append(f"- **Flags:** {', '.join(r['flags'])}")
            if r.get("good_to_know"):
                lines.append(f"- **Good to Know:** {'; '.join(r['good_to_know'])}")
            verified = r.get("verified")
            if verified is True:
                lines.append(f"- **Verification:** ✅ Passed")
            elif verified is False:
                lines.append(f"- **Verification:** ⚠️ Failed — {'; '.join(r.get('verification_notes', []))}")
            elif verified is None and r.get("verification_notes"):
                lines.append(f"- **Verification:** ❓ {'; '.join(r.get('verification_notes', []))}")
            lines.append("")
    else:
        lines.append("No new listings found today.")

    lines.append(f"\n---\n*Generated: {datetime.now().strftime('%Y-%m-%d %H:%M')}*")
    archive_file.write_text("\n".join(lines))
    log(f"ARCHIVE: Saved to {archive_file}")


def format_sms(results: list[dict], min_score: int) -> str:
    """Format top results as an SMS message."""
    top = [r for r in results if r.get("score", 0) >= min_score]
    if not top:
        return ""

    lines = [f"🏡 NIGHTLY SCRAPER: {len(top)} new listing{'s' if len(top) != 1 else ''} matching your criteria!\n"]

    for r in top[:5]:  # Cap at 5 in SMS
        price = r.get("price", "?")
        price_str = f"${price:,}" if isinstance(price, (int, float)) else str(price)

        drive = r.get("drive_from_home", {})
        drive_text = ""
        if drive:
            h = drive.get("hours", 0)
            m = drive.get("minutes", 0)
            mi = drive.get("miles", 0)
            drive_text = f"🚗 {int(h)}hr {int(m % 60)}min ({int(mi)} mi)"

        ski_parts = []
        ski_driving = r.get("ski_driving") or []
        for s in ski_driving[:2]:
            if isinstance(s, dict):
                ski_parts.append(f"{s.get('drive_minutes', '?')}min to {s.get('name', '?')}")
        ski_text = "⛷️ " + ", ".join(ski_parts) if ski_parts else "⛷️ ski distance unknown"

        score = r.get("score", "?")
        vibe = r.get("vibe_match", "?")

        verified = r.get("verified")
        v_icon = " ✅" if verified is True else " ⚠️" if verified is False else ""
        lines.append(f"{'⭐' if score >= 8 else '🔹'} {r.get('address', '?')} — {price_str}")
        if r.get("url"):
            lines.append(f"   {r['url']}")
        lines.append(f"   {r.get('beds', '?')}bd/{r.get('baths', '?')}ba | {r.get('acres', '?')} acres | Score: {score}/10 (vibe: {vibe}){v_icon}")
        if drive_text:
            lines.append(f"   {drive_text}")
        lines.append(f"   {ski_text}")
        lines.append(f"   {r.get('summary', '')}")
        if r.get("good_to_know"):
            gtk_text = "; ".join(r["good_to_know"])
            lines.append(f"   ⚠️ Good to Know: {gtk_text}")
        lines.append("")

    if len(results) > 5:
        remaining = len([r for r in results[5:] if r.get("score", 0) >= min_score])
        if remaining:
            lines.append(f"+ {remaining} more — check ~/Documents/vacation-houses/{date.today().isoformat()}/ for full results")

    return "\n".join(lines)


def send_sms(message: str):
    """Send SMS to the group chat."""
    if not message:
        return
    log(f"NOTIFY: Sending SMS ({len(message)} chars)")
    try:
        subprocess.run(
            [str(SMS_SCRIPT), CHAT_ID, message],
            capture_output=True, text=True, timeout=30,
        )
        log("NOTIFY: SMS sent successfully")
    except Exception as e:
        log(f"NOTIFY: SMS failed: {e}")


def main():
    parser = argparse.ArgumentParser(description="Nightly vacation house scraper")
    parser.add_argument("--notify", action="store_true", help="Send SMS if matches found")
    parser.add_argument("--dry-run", action="store_true", help="Discovery only, no D1 sync")
    parser.add_argument("--min-score", type=int, default=6, help="Min AI score to report (default: 6)")
    parser.add_argument("--max-price", type=int, default=SEARCH_CRITERIA["max_price"], help="Max price")
    parser.add_argument("--json", action="store_true", help="JSON output")
    args = parser.parse_args()

    SEARCH_CRITERIA["max_price"] = args.max_price

    log("=" * 60)
    log("NIGHTLY SCRAPER: Starting pipeline")
    log("=" * 60)

    # Step 1: Discovery — search all sources
    all_listings = run_unified_search()
    if not all_listings:
        log("No listings found. Exiting.")
        if args.json:
            print(json.dumps({"new": 0, "results": []}))
        return

    # Step 2: Dedupe — filter out already-seen listings
    if args.dry_run:
        new_listings = all_listings
        log("DRY RUN: Skipping D1 dedupe")
    else:
        existing = get_existing_addresses()
        new_listings = filter_new_listings(all_listings, existing)

        # Sync ALL listings to D1 (updates last_seen for existing, creates new)
        sync_to_d1(all_listings)

    if not new_listings:
        log("No new listings. Nothing to refine.")
        save_archive([], all_listings)
        if args.json:
            print(json.dumps({"new": 0, "results": []}))
        if args.notify:
            log("NOTIFY: No new listings, skipping SMS")
        return

    # Step 2.5: Pre-filter by hard requirements (skip obviously wrong listings before expensive enrichment)
    pre_filtered = []
    for l in new_listings:
        baths = l.get("baths", 0) or 0
        beds = l.get("beds", 0) or 0
        addr = l.get("address", "?")
        # Skip land-only listings (0 beds AND 0 baths = vacant land, not a house)
        if (isinstance(beds, (int, float)) and beds == 0 and
            isinstance(baths, (int, float)) and baths == 0):
            log(f"PRE-FILTER: Skipping {addr} — land only (0 beds, 0 baths)")
            continue
        # Skip if description/address suggests vacant land
        desc = (l.get("description", "") or "").lower()
        addr_lower = addr.lower()
        land_keywords = ["vacant land", "buildable lot", "land only", "raw land", "undeveloped"]
        if any(kw in desc or kw in addr_lower for kw in land_keywords):
            log(f"PRE-FILTER: Skipping {addr} — land-only listing (keyword match)")
            continue
        # Only filter if we KNOW they fail (missing data passes through)
        if isinstance(baths, (int, float)) and baths > 0 and baths < 2:
            log(f"PRE-FILTER: Skipping {addr} — only {baths} baths")
            continue
        if isinstance(beds, (int, float)) and beds > 0 and beds < 3:
            log(f"PRE-FILTER: Skipping {addr} — only {beds} beds")
            continue
        pre_filtered.append(l)
    log(f"PRE-FILTER: {len(pre_filtered)} listings pass (from {len(new_listings)} new)")

    # Step 3: Enrichment — web search for details + Google Places nearby
    enriched = enrich_listings(pre_filtered)

    # Step 3b: Ski distance enrichment — ensure every listing has driving distances
    log("SKI ENRICHMENT: Ensuring all listings have ski mountain distances...")
    enriched = enrich_ski_distances(enriched)

    # Step 3c: Parcel data enrichment — VCGI parcel boundaries + assessed values
    log("PARCEL ENRICHMENT: Fetching VCGI parcel data...")
    enriched = enrich_parcel_data(enriched)

    # Step 4: Refinement — AI-score each enriched listing
    scored = refine_listings(enriched)

    # Step 5: Verification — cross-check enriched data against source text
    verified = verify_listings(scored)

    # Step 6: Archive results
    save_archive(verified, all_listings)

    # Step 7: Output
    top_matches = [r for r in verified if r.get("score", 0) >= args.min_score]
    log(f"RESULTS: {len(top_matches)} listings scored {args.min_score}+/10 (out of {len(verified)} new)")

    if args.json:
        print(json.dumps({"new": len(new_listings), "results": verified}, indent=2))
    else:
        for r in verified:
            score = r.get("score", "?")
            marker = "⭐" if score >= 8 else "🔹" if score >= args.min_score else "  "
            print(f"{marker} [{score}/10] {r.get('address', '?')} — ${r.get('price', '?'):,} — {r.get('summary', '')}")

    # Step 8: Notify
    if args.notify and top_matches:
        message = format_sms(verified, args.min_score)
        send_sms(message)
    elif args.notify:
        log("NOTIFY: No matches above threshold, skipping SMS")

    log("NIGHTLY SCRAPER: Pipeline complete")


if __name__ == "__main__":
    main()
