#!/usr/bin/env -S uv run --script
# /// script
# requires-python = ">=3.11"
# dependencies = ["requests"]
# ///
"""
Nightly Vacation House Scraper — Discovery + Enrichment + Refinement + Verification Pipeline

1. DISCOVERY: Runs unified-search across all sources
2. DEDUPE: Compares against Cloudflare D1 (skips already-seen listings)
3. ENRICHMENT: Parallel web search + Google Places nearby check for each listing
4. REFINEMENT: Parallel AI scoring of enriched listings against preferences + favorites
5. VERIFICATION: Cross-checks enriched data against source text to catch hallucinations
6. OUTPUT: Returns top matches as JSON, optionally sends SMS

Usage:
    nightly-scraper                     # Run full pipeline, print results
    nightly-scraper --notify            # Run + send SMS if matches found
    nightly-scraper --dry-run           # Discovery only, no D1 sync
    nightly-scraper --min-score 7       # Only report listings scoring 7+/10
"""

