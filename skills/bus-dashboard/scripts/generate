#!/usr/bin/env -S uv run --script
# /// script
# requires-python = ">=3.11"
# ///
"""Generate a Dispatch Bus dashboard HTML from bus.db.

Usage:
  generate [--hours N] [--output PATH] [--publish] [--public]

Options:
  --hours N      Hours to look back (default: 6)
  --output PATH  Output HTML file path (default: /tmp/bus-dashboard/index.html)
  --publish      Publish to sven-pages after generating
  --public       Make published page public (implies --publish)
"""

import argparse
import json
import os
import sqlite3
import subprocess
import sys
import time
from datetime import datetime
from pathlib import Path


def query_bus_data(db_path: str, hours: int) -> dict:
    conn = sqlite3.connect(db_path)
    cutoff = int((time.time() - hours * 3600) * 1000)

    # Total records
    total = conn.execute(
        "SELECT COUNT(*) FROM records WHERE timestamp > ?", (cutoff,)
    ).fetchone()[0]

    # Time range
    time_range = conn.execute(
        "SELECT MIN(timestamp), MAX(timestamp) FROM records WHERE timestamp > ?",
        (cutoff,),
    ).fetchone()
    start_time = datetime.fromtimestamp(time_range[0] / 1000) if time_range[0] else None
    end_time = datetime.fromtimestamp(time_range[1] / 1000) if time_range[1] else None

    # Topics
    topics = conn.execute("SELECT COUNT(*) FROM topics").fetchone()[0]

    # Event type counts
    event_types = conn.execute(
        """SELECT topic, type, COUNT(*) as cnt FROM records
           WHERE timestamp > ? GROUP BY topic, type ORDER BY cnt DESC""",
        (cutoff,),
    ).fetchall()

    # 15-min buckets
    rows = conn.execute(
        "SELECT timestamp FROM records WHERE timestamp > ? ORDER BY timestamp",
        (cutoff,),
    ).fetchall()
    buckets = {}
    for (ts,) in rows:
        dt = datetime.fromtimestamp(ts / 1000)
        bucket = dt.strftime("%H:") + str(dt.minute // 15 * 15).zfill(2)
        buckets[bucket] = buckets.get(bucket, 0) + 1

    # Messages per contact/group
    msg_rows = conn.execute(
        """SELECT payload FROM records
           WHERE timestamp > ? AND type = 'message.received'""",
        (cutoff,),
    ).fetchall()
    contact_msgs = {}
    for (payload_str,) in msg_rows:
        try:
            p = json.loads(payload_str)
            name = p.get("group_name") or p.get("phone", "unknown")
            contact_msgs[name] = contact_msgs.get(name, 0) + 1
        except Exception:
            pass

    # Turn durations per session
    turn_rows = conn.execute(
        """SELECT payload FROM records
           WHERE timestamp > ? AND type = 'sdk.turn_complete'""",
        (cutoff,),
    ).fetchall()
    session_durs = {}
    all_durs = []
    for (payload_str,) in turn_rows:
        try:
            p = json.loads(payload_str)
            name = p.get("contact_name", "unknown")
            d = p.get("duration_ms", 0)
            if d > 0:
                session_durs.setdefault(name, []).append(d)
                all_durs.append(d)
        except Exception:
            pass

    # Unique sessions
    session_names = set()
    contact_names = set()
    all_rows = conn.execute(
        "SELECT payload FROM records WHERE timestamp > ?", (cutoff,)
    ).fetchall()
    for (payload_str,) in all_rows:
        try:
            p = json.loads(payload_str)
            if p.get("session_name"):
                session_names.add(p["session_name"])
            if p.get("contact_name"):
                contact_names.add(p["contact_name"])
            if p.get("group_name"):
                contact_names.add(p["group_name"])
        except Exception:
            pass

    # Lifecycle events
    lifecycle = []
    lc_rows = conn.execute(
        """SELECT type, timestamp FROM records
           WHERE timestamp > ? AND type IN (
               'daemon.started', 'daemon.stopped', 'healme.triggered',
               'compaction.triggered', 'session.killed', 'session.restarted'
           ) ORDER BY timestamp""",
        (cutoff,),
    ).fetchall()
    for evt_type, ts in lc_rows:
        dt = datetime.fromtimestamp(ts / 1000)
        lifecycle.append({"time": dt.strftime("%H:%M:%S"), "type": evt_type})

    conn.close()

    return {
        "total": total,
        "topics": topics,
        "sessions": len(session_names),
        "contacts": len([c for c in contact_names if c]),
        "start_time": start_time,
        "end_time": end_time,
        "event_types": [
            {"topic": t, "type": ty, "count": c} for t, ty, c in event_types
        ],
        "buckets": dict(sorted(buckets.items())),
        "contact_msgs": dict(
            sorted(contact_msgs.items(), key=lambda x: -x[1])
        ),
        "session_durs": {
            k: {"avg": sum(v) / len(v) / 1000, "count": len(v)}
            for k, v in sorted(session_durs.items())
        },
        "avg_response": sum(all_durs) / len(all_durs) / 1000 if all_durs else 0,
        "turn_count": len(all_durs),
        "lifecycle": lifecycle,
    }


def get_topic_class(topic: str) -> str:
    if topic == "messages":
        return "msg"
    if topic == "sessions":
        return "session"
    return "system"


def get_lifecycle_class(evt_type: str) -> str:
    mapping = {
        "daemon.started": "started",
        "daemon.stopped": "stopped",
        "healme.triggered": "healme",
        "compaction.triggered": "compaction",
        "session.killed": "stopped",
        "session.restarted": "started",
    }
    return mapping.get(evt_type, "started")


# Friendly name mapping for known group/session slugs
FRIENDLY_NAMES = {}


def friendly_name(raw: str) -> str:
    """Convert raw session/group names to human-readable names."""
    if raw in FRIENDLY_NAMES:
        return FRIENDLY_NAMES[raw]
    # Clean up common patterns
    if raw.startswith("+"):
        return raw  # phone numbers stay as-is
    # Replace hyphens with " + " for group names
    if "-" in raw and not raw.startswith("."):
        parts = raw.split("-")
        return " + ".join(p.capitalize() for p in parts)
    return raw


def generate_html(data: dict, hours: int) -> str:
    now = datetime.now()
    start_hour = data["start_time"].strftime("%H:%M") if data["start_time"] else "?"
    end_hour = data["end_time"].strftime("%H:%M") if data["end_time"] else "?"
    date_str = now.strftime("%b %d, %Y")

    # Get key stats
    msgs_in = sum(
        e["count"] for e in data["event_types"] if e["type"] == "message.received"
    )
    injections = sum(
        e["count"] for e in data["event_types"] if e["type"] == "session.injected"
    )
    daemon_starts = sum(
        e["count"] for e in data["event_types"] if e["type"] == "daemon.started"
    )
    avg_resp = f"{data['avg_response']:.0f}s"

    # Timeline JSON
    timeline_json = json.dumps(
        [{"t": k, "v": v} for k, v in data["buckets"].items()]
    )

    # Contacts JSON
    contacts_json = json.dumps(
        [
            {"name": friendly_name(k), "count": v}
            for k, v in data["contact_msgs"].items()
        ]
    )

    # Events JSON
    events_json = json.dumps(
        [
            {
                "type": e["type"],
                "count": e["count"],
                "topic": get_topic_class(e["topic"]),
            }
            for e in data["event_types"]
        ]
    )

    # Response times JSON
    responses_json = json.dumps(
        [
            {
                "name": friendly_name(k),
                "avg": round(v["avg"], 1),
                "unit": "s",
                "count": v["count"],
            }
            for k, v in sorted(
                data["session_durs"].items(), key=lambda x: x[1]["avg"]
            )
        ]
    )

    # Lifecycle JSON
    lifecycle_json = json.dumps(
        [
            {"time": e["time"], "type": get_lifecycle_class(e["type"])}
            for e in data["lifecycle"]
        ]
    )

    # Find spike bucket
    max_bucket = max(data["buckets"].items(), key=lambda x: x[1]) if data["buckets"] else ("?", 0)
    spike_callout = ""
    if max_bucket[1] > 150:  # significant spike
        spike_callout = f"""
  <div class="callout animate-in delay-3">
    <span class="callout-icon">⚡</span>
    <div>
      <strong>{max_bucket[0]} — {max_bucket[1]} events in 15 minutes.</strong>
      Significant activity spike detected in this window.
    </div>
  </div>"""

    # Determine lifecycle time range
    if data["start_time"] and data["end_time"]:
        lc_start_hour = data["start_time"].hour
        lc_end_hour = data["end_time"].hour + 1
    else:
        lc_start_hour = 0
        lc_end_hour = 24

    lc_labels = " ".join(
        f"<span>{h}:00</span>" for h in range(lc_start_hour, lc_end_hour + 1)
    )

    gen_time = now.strftime("%b %d, %Y %-I:%M %p")

    return f"""<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Dispatch Bus — {hours} Hour Window</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet">
<style>
  :root {{
    --ink: #1a1816;
    --ink-secondary: #5c5650;
    --ink-tertiary: #8a8279;
    --ink-muted: #b5ada5;
    --surface-0: #f7f5f2;
    --surface-1: #edeae6;
    --surface-2: #e3e0db;
    --surface-3: #d9d5cf;
    --border: rgba(26, 24, 22, 0.08);
    --border-emphasis: rgba(26, 24, 22, 0.15);
    --signal-orange: #c2410c;
    --signal-orange-soft: rgba(194, 65, 12, 0.08);
    --signal-green: #15803d;
    --signal-green-soft: rgba(21, 128, 61, 0.08);
    --signal-red: #b91c1c;
    --signal-red-soft: rgba(185, 28, 28, 0.08);
    --signal-blue: #1d4ed8;
    --signal-blue-soft: rgba(29, 78, 216, 0.06);
  }}
