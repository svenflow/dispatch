<script>
const timeline = {timeline_json};
const maxV = Math.max(...timeline.map(d => d.v));
const el = document.getElementById("timeline");
timeline.forEach((d, i) => {{
  const group = document.createElement("div");
  group.className = "timeline-bar-group";
  const h = Math.max(2, (d.v / maxV) * 130);
  const isSpike = d.v > maxV * 0.6;
  const isLast = i === timeline.length - 1;
  group.innerHTML = `
    <div class="timeline-tooltip">${{d.v}}${{isLast ? ' (partial)' : ''}}</div>
    <div class="timeline-bar${{isSpike ? ' spike' : ''}}" style="height:${{h}}px;${{isLast ? 'opacity:0.35;' : ''}}"></div>
    ${{i % 4 === 0 ? `<span class="timeline-label">${{d.t}}</span>` : ''}}
  `;
  el.appendChild(group);
}});

const contacts = {contacts_json};
const maxMsg = contacts[0]?.count || 1;
const contactsEl = document.getElementById("contacts");
contacts.forEach(c => {{
  const row = document.createElement("div");
  row.className = "contact-row";
  row.innerHTML = `
    <span class="contact-name">${{c.name}}</span>
    <span class="contact-count">${{c.count}}</span>
    <div class="contact-bar-wrap"><div class="contact-bar" style="width:${{(c.count/maxMsg)*100}}%"></div></div>
  `;
  contactsEl.appendChild(row);
}});

const events = {events_json};
const eventsEl = document.getElementById("events");
events.forEach(e => {{
  const dotClass = e.topic === "msg" ? "dot-msg" : e.topic === "session" ? "dot-session" : "dot-system";
  const row = document.createElement("div");
  row.className = "event-row";
  row.innerHTML = `
    <span class="event-type"><span class="dot ${{dotClass}}"></span>${{e.type}}</span>
    <span class="event-count">${{e.count}}</span>
  `;
  eventsEl.appendChild(row);
}});

const responses = {responses_json};
const responsesEl = document.getElementById("responses");
responses.forEach(r => {{
  const card = document.createElement("div");
  card.className = "response-card";
  card.innerHTML = `
    <div class="response-name">${{r.name}}</div>
    <div class="response-time">${{r.avg}}<span class="response-unit">${{r.unit}}</span></div>
    <div class="response-meta">${{r.count}} turns</div>
  `;
  responsesEl.appendChild(card);
}});

const lifecycleEvents = {lifecycle_json};
const track = document.getElementById("lifecycle-track");
const startMin = {lc_start_hour} * 60;
const endMin = {lc_end_hour} * 60;
const rangeMin = endMin - startMin;
lifecycleEvents.forEach(e => {{
  const parts = e.time.split(":");
  const mins = parseInt(parts[0]) * 60 + parseInt(parts[1]) + parseInt(parts[2]) / 60;
  const pct = ((mins - startMin) / rangeMin) * 100;
  const dot = document.createElement("div");
  dot.className = `lifecycle-event ${{e.type}}`;
  dot.style.left = `${{pct}}%`;
  dot.title = `${{e.time}} — ${{e.type}}`;
  track.appendChild(dot);
}});
</script>
</body>
</html>"""


def main():
    parser = argparse.ArgumentParser(description="Generate Dispatch Bus dashboard")
    parser.add_argument("--hours", type=int, default=6, help="Hours to look back")
    parser.add_argument(
        "--output",
        default="/tmp/bus-dashboard/index.html",
        help="Output HTML path",
    )
    parser.add_argument(
        "--db",
        default=os.path.expanduser("~/dispatch/state/bus.db"),
        help="Path to bus.db",
    )
    parser.add_argument("--publish", action="store_true", help="Publish to sven-pages")
    parser.add_argument(
        "--public", action="store_true", help="Make published page public"
    )
    args = parser.parse_args()

    if args.public:
        args.publish = True

    if not os.path.exists(args.db):
        print(f"Error: {args.db} not found", file=sys.stderr)
        sys.exit(1)

    print(f"Querying bus.db for last {args.hours} hours...")
    data = query_bus_data(args.db, args.hours)
    print(f"Found {data['total']:,} events")

    html = generate_html(data, args.hours)

    output_path = Path(args.output)
    output_path.parent.mkdir(parents=True, exist_ok=True)
    output_path.write_text(html)
    print(f"Written to {output_path}")

    if args.publish:
        publish_script = os.path.expanduser(
            "~/.claude/skills/sven-pages/scripts/publish"
        )
        cmd = [publish_script, str(output_path.parent)]
        if args.public:
            cmd.append("--public")
        result = subprocess.run(cmd, capture_output=True, text=True)
        print(result.stdout)
        if result.returncode != 0:
            print(result.stderr, file=sys.stderr)
            sys.exit(1)


if __name__ == "__main__":
    main()
