  .header .window {{ font-family: 'JetBrains Mono', monospace; font-size: 13px; color: var(--ink-tertiary); }}
  .subtitle {{ font-size: 14px; color: var(--ink-secondary); margin-bottom: 48px; line-height: 1.5; }}
  .subtitle strong {{ color: var(--ink); font-weight: 600; }}
  .pulse-row {{ display: flex; align-items: center; gap: 8px; margin-bottom: 48px; }}
  .pulse-dot {{ width: 8px; height: 8px; border-radius: 50%; background: var(--ink-tertiary); opacity: 0.5; }}
