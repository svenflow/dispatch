#!/usr/bin/env -S uv run --script
# /// script
# requires-python = ">=3.11"
# dependencies = [
#     "scrapling[all]>=0.4",
#     "markdownify>=0.11",
#     "beautifulsoup4>=4.12",
# ]
# ///
"""
webfetch - Fetch web pages with anti-bot bypass using scrapling.

Usage:
    webfetch <url> [--timeout SECONDS] [--raw] [--tier TIER]

Tiered fetching strategy:
  Tier 1: scrapling HTTP (TLS fingerprint spoofing, fastest)
  Tier 2: scrapling StealthyFetcher (Camoufox Firefox, for Cloudflare)
  Fallback: chrome-control extension (for auth-required sites)

By default, tries tiers in order until one succeeds.
"""

import argparse
import sys
import re
from urllib.parse import urlparse

from bs4 import BeautifulSoup
from markdownify import markdownify as md


def fetch_with_scrapling_http(url: str, timeout: int = 30) -> tuple[str | None, str | None]:
    """Tier 1: Fast HTTP fetch with TLS fingerprint spoofing."""
    try:
        from scrapling import Fetcher

        fetcher = Fetcher()
        page = fetcher.get(url, timeout=timeout)
        html = page.html_content if hasattr(page, 'html_content') else None

        if html and len(html) > 500:
            return html, None
        return None, "Empty or minimal content"
    except Exception as e:
        return None, str(e)


def fetch_with_scrapling_stealthy(url: str, timeout: int = 30, network_idle: bool = False,
                                   wait: int = 0, wait_selector: str = None) -> tuple[str | None, str | None]:
    """Tier 2: Stealthy fetch with Camoufox (Firefox-based).
    
    Args:
        network_idle: Wait until no network connections for 500ms (good for JS-rendered SPAs)
        wait: Extra milliseconds to wait after page loads (e.g. 2000 for 2s buffer)
        wait_selector: CSS selector to wait for before returning (e.g. "[data-rf-test-id=\'abp-price\']")
    """
    try:
        from scrapling import StealthyFetcher

        fetcher = StealthyFetcher()
        fetch_kwargs = {
            "headless": True,
            "timeout": timeout * 1000,
        }
        if network_idle:
            fetch_kwargs["network_idle"] = True
        if wait > 0:
            fetch_kwargs["wait"] = wait
        if wait_selector:
            fetch_kwargs["wait_selector"] = wait_selector
            fetch_kwargs["wait_selector_state"] = "visible"

        page = fetcher.fetch(url, **fetch_kwargs)
        html = page.html_content if hasattr(page, 'html_content') else None

        if html and len(html) > 500:
            return html, None
        return None, "Empty or minimal content"
    except Exception as e:
        return None, str(e)


def html_to_markdown(html: str, url: str) -> str:
    """Convert HTML to clean markdown."""
    soup = BeautifulSoup(html, "html.parser")

    # Remove script, style, nav, footer, header elements
    for tag in soup.find_all(
        ["script", "style", "nav", "footer", "header", "aside", "noscript"]
    ):
        tag.decompose()

    # Try to find main content
    main = (
        soup.find("main")
        or soup.find("article")
        or soup.find(id="content")
        or soup.find(class_="content")
    )
    if main:
        content = str(main)
    else:
        # Fall back to body
        body = soup.find("body")
        content = str(body) if body else str(soup)

    # Convert to markdown
    markdown = md(content, heading_style="ATX", strip=["img"])

    # Clean up excessive whitespace
    markdown = re.sub(r"\n{3,}", "\n\n", markdown)
    markdown = markdown.strip()

    # Add source URL
    domain = urlparse(url).netloc
    return f"*Source: {domain}*\n\n{markdown}"


def looks_like_antibot_page(html: str) -> bool:
    """Check if the page looks like an antibot challenge (not just mentions cloudflare)."""
    if len(html) < 500:
        return True

    # Only flag as antibot if these specific challenge patterns appear
    challenge_patterns = [
        "checking your browser",
        "just a moment",
        "please wait while we verify",
        "verify you are human",
        "cf-browser-verification",
        "challenge-running",
        "security check required",
        "access denied",
        "unusual traffic",
    ]

    html_lower = html.lower()

    # Must match challenge pattern AND have minimal real content
    has_challenge = any(pattern in html_lower for pattern in challenge_patterns)

    # If page has substantial content (>10KB), it's probably real even with challenge text
    if len(html) > 10000:
        return False

    return has_challenge


def main():
    parser = argparse.ArgumentParser(description="Fetch web pages with anti-bot bypass")
    parser.add_argument("url", help="URL to fetch")
    parser.add_argument("--timeout", type=int, default=30, help="Timeout in seconds")
    parser.add_argument(
        "--raw", action="store_true", help="Output raw HTML instead of markdown"
    )
    parser.add_argument(
        "--tier", type=int, choices=[1, 2], default=0,
        help="Force specific tier (1=scrapling HTTP, 2=scrapling Stealthy)"
    )
    parser.add_argument(
        "--network-idle", action="store_true",
        help="Wait for network idle (no connections for 500ms) — good for JS-rendered pages"
    )
    parser.add_argument(
        "--wait", type=int, default=0,
        help="Extra milliseconds to wait after page loads (e.g. 2000)"
    )
    parser.add_argument(
        "--wait-selector", type=str, default=None,
        help="CSS selector to wait for before returning content"
    )
    # Deprecated flags kept for backwards compat
    parser.add_argument("--force-headless", action="store_true", help="Deprecated")
    parser.add_argument("--force-playwright", action="store_true", help="Deprecated")
    parser.add_argument("--no-cookies", action="store_true", help="Deprecated")
    args = parser.parse_args()

    url = args.url
    if not url.startswith(("http://", "https://")):
        url = "https://" + url

    html = None
    error = None
    tier_used = None

    # Try tiers in order (or use forced tier)
    tiers = [args.tier] if args.tier else [1, 2]

    for tier in tiers:
        if tier == 1:
            print("[tier 1] scrapling HTTP (TLS fingerprint)...", file=sys.stderr)
            html, error = fetch_with_scrapling_http(url, args.timeout)
            if html and not looks_like_antibot_page(html):
                tier_used = 1
                break
            print(f"[tier 1] failed: {error or 'antibot detected'}", file=sys.stderr)

        elif tier == 2:
            print("[tier 2] scrapling Stealthy (Camoufox)...", file=sys.stderr)
            html, error = fetch_with_scrapling_stealthy(
                    url, args.timeout,
                    network_idle=args.network_idle,
                    wait=args.wait,
                    wait_selector=args.wait_selector,
                )
            if html and not looks_like_antibot_page(html):
                tier_used = 2
                break
            print(f"[tier 2] failed: {error or 'antibot detected'}", file=sys.stderr)

    if not html:
        print(f"All tiers failed. Last error: {error}", file=sys.stderr)
        print(f"Try chrome-control: ~/.claude/skills/chrome-control/scripts/chrome fetch \"{url}\"", file=sys.stderr)
        sys.exit(1)

    # Output
    if args.raw:
        print(html)
    else:
        markdown = html_to_markdown(html, url)
        print(markdown)

    print(f"\n[Fetched with tier {tier_used}]", file=sys.stderr)


if __name__ == "__main__":
    main()
