"""
Twitter/X CLI - Interact with X via authenticated API calls.

Authentication uses Chrome session cookies (no API keys needed).
"""

from __future__ import annotations

import argparse
import json
import os
import re
import subprocess
import sys
import time
from pathlib import Path
from urllib.parse import quote

from curl_cffi import CurlMime, requests

# X's public web bearer token (same for all web users)
BEARER = "AAAAAAAAAAAAAAAAAAAAANRILgAAAAAAnNwIzUejRCOuH5E6I8xnZz4puTs%3D1Zv7ttfk8LF81IUq16cHjhLTvJu4FA33AGWWjCpTnA"

# Default GraphQL query IDs (may need refreshing)
DEFAULT_QUERY_IDS = {
    "CreateTweet": "zkcFc6F-RKRgWN8HUkJfZg",
    "DeleteTweet": "VaenaVgh5q5ih7kvyVjgtg",
    "HomeTimeline": "L8Lb9oomccM012S7fQ-QKA",
    "UserByScreenName": "IGgvgiOx4QZndDHuD3x9TQ",
    "UserTweets": "E3opETHurmVJflFsUBVuUQ",
